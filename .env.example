# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://mbybrzggrpyhvcnxhlua.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>
VITE_SUPABASE_PROJECT_ID=mbybrzggrpyhvcnxhlua

# ── Edge Function Secrets (set via: npx supabase secrets set KEY=value) ──────
# These are NOT read by the frontend. Set them in Supabase, not in .env.
#
# RESEND_API_KEY=re_...              # Resend API key for outbound email
# RESEND_FROM_EMAIL=noreply@routeaceglyde.app  # Verified sender (optional override)
# WEBHOOK_SECRET=<hmac-secret>       # Auth email hook signing secret
# SUPABASE_SERVICE_ROLE_KEY=<key>    # Auto-injected by Supabase runtime
# ALLOWED_ORIGIN=https://routeaceglyde.app  # CORS allowed origin for edge functions
