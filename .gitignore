# Environment — never commit real credentials
.env
.env.local
.env.*.local

# Allow committed env files (contain only public/anon keys — no secrets)
!.env.production
!.env.development

# Bun lock files — Cloudflare must use npm (package-lock.json)
bun.lock
bun.lockb

# Supabase temp files
supabase/.temp/

# Large video assets — served from Supabase Storage / CDN, not committed to git
src/assets/**/*.mp4
src/assets/**/*.mov
src/assets/**/*.webm

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
